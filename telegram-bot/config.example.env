# ─── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ─── Fix Server ──────────────────────────────────────────────────────────────
FIX_SERVER_URL=http://127.0.0.1:3011
FIX_SERVER_TOKEN=change_this_to_a_secret_token
FIX_SERVER_PORT=3011
FIX_SERVER_HOST=127.0.0.1

# ─── Monitor (optional) ──────────────────────────────────────────────────────
MONITOR_SERVER_NAME=my-server
MONITOR_TIMEZONE=Asia/Kolkata
NGINX_SERVICE=auto           # auto | nginx-rc | nginx
MONITOR_PORTS=3002,3003,3005 # comma-separated ports to check
MONITOR_RAM_THRESHOLD=800    # alert if free RAM below this (MB)
MONITOR_DISK_THRESHOLD=85    # alert if disk above this (%)
MONITOR_ORPHAN_THRESHOLD=5   # alert if orphan procs above this
MONITOR_LOAD_THRESHOLD=150   # alert if CPU load% above this
MONITOR_COOLDOWN=1800        # seconds before re-alerting same issue
